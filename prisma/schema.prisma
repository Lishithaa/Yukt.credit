generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CA
  MSME
  LENDER
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  DOCUMENT_UPLOADED
  UNDERWRITING
  LENDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

enum LoanPurpose {
  WORKING_CAPITAL
  EXPANSION
  EQUIPMENT
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(MSME)
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  caProfile     CAProfile?
  msmeProfile   MSMEProfile?
  lenderProfile LenderProfile?
}

model CAProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  icaiRegNo   String
  firmName    String
  city        String
  bankAccount String?
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients     CAClient[]
  commissions Commission[]
}

model MSMEProfile {
  id              String            @id @default(cuid())
  userId          String            @unique
  businessName    String
  gstNumber       String
  yearsInBusiness Int
  monthlyTurnover Float
  createdAt       DateTime          @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    LoanApplication[]
}

model LenderProfile {
  id                String @id @default(cuid())
  userId            String @unique
  institutionName   String
  institutionType   String
  contactName       String?
  defaultCommission Float  @default(1.5)
  payoutBankDetails String?

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CAClient {
  id                   String            @id @default(cuid())
  caProfileId          String
  name                 String
  businessName         String
  gstNumber            String
  annualTurnover       Float
  loanAmountRequired   Float
  gstCertificateBase64 String
  itrBase64            String
  bankStatementsBase64 String
  createdAt            DateTime          @default(now())

  caProfile            CAProfile         @relation(fields: [caProfileId], references: [id], onDelete: Cascade)
  applications         LoanApplication[]
}

model LoanApplication {
  id                   String            @id @default(cuid())
  msmeProfileId        String?
  caClientId           String?
  loanAmount           Float
  purpose              LoanPurpose
  status               ApplicationStatus @default(DRAFT)

  gstCertificateBase64 String?
  itrBase64            String?
  bankStatementsBase64 String?

  sellerConnected      Boolean           @default(false)
  sellerPlatform       String?
  sellerOrderVolume    Int?
  sellerReturnRate     Float?
  sellerRating         Float?

  creditScore          Int?
  aiRecommendation     String?
  riskFactors          String[]
  rejectionReason      String?
  commissionRate       Float?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  msmeProfile          MSMEProfile?      @relation(fields: [msmeProfileId], references: [id], onDelete: SetNull)
  caClient             CAClient?         @relation(fields: [caClientId], references: [id], onDelete: SetNull)
}

model Commission {
  id                String   @id @default(cuid())
  caProfileId       String
  loanApplicationId String
  amount            Float
  rate              Float
  createdAt         DateTime @default(now())

  caProfile         CAProfile @relation(fields: [caProfileId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
