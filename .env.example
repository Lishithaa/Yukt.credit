# DigitalOcean Managed MySQL — use the "Connection string" from the DB dashboard.
# Prisma format (not SQLAlchemy mysql+aiomysql). Create a database named yukt in DO, or use defaultdb.
# TLS is required on port 25060.
DATABASE_URL="mysql://doadmin:YOUR_PASSWORD@YOUR_HOST.db.ondigitalocean.com:25060/yukt?sslaccept=strict"

# App URL must match your DigitalOcean app hostname (https).
NEXTAUTH_URL="https://your-app.ondigitalocean.app"
NEXTAUTH_SECRET="generate-a-long-random-secret"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
